// Armstrong — Prisma Schema
// Database: PostgreSQL 16
// Run: npx prisma db push (dev) or npx prisma migrate dev (prod)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// LEADS
// All form submissions create a Lead record.
// ─────────────────────────────────────────────

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Contact info
  firstName String
  lastName  String
  email     String
  phone     String

  // Move details
  type        LeadType
  originZip   String?
  destZip     String?
  moveDate    DateTime?
  notes       String?

  // Source attribution (server-enriched)
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  referrer    String?
  sessionId   String?
  formPage    String?

  // Geo (MaxMind enrichment)
  geoCity     String?
  geoState    String?
  geoCountry  String?
  geoDma      String?

  // Device
  device      DeviceType?
  browser     String?

  // Lead scoring
  score       Int      @default(0)
  scoreBreakdown Json? // { page_views: 20, estimate_complete: 40, ... }

  // Status
  status      LeadStatus @default(NEW)
  assignedTo  String?    // sales rep email
  netsuiteId  String?    // NetSuite internal ID after sync

  // CRM sync
  netsuiteSyncedAt DateTime?
  netsuiteSyncError String?

  // Relations
  events      TrackingEvent[]
  estimates   Estimate[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([score])
  @@index([sessionId])
}

enum LeadType {
  RESIDENTIAL
  COMMERCIAL
  SUPPLY_CHAIN
  DATA_CENTER
  CREDIT_APPLICATION
  SUPPLIES_ESTIMATE
  VIRTUAL_SURVEY
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  QUOTED
  CLOSED_WON
  CLOSED_LOST
  UNQUALIFIED
}

enum DeviceType {
  DESKTOP
  TABLET
  MOBILE
}

// ─────────────────────────────────────────────
// ESTIMATES
// Results from the ballpark estimate tool.
// ─────────────────────────────────────────────

model Estimate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])
  sessionId String?

  // Inputs
  moveType      LeadType
  originZip     String
  destZip       String
  moveDate      DateTime?
  homeSizeTier  String   // "studio" | "1br" | "2br" | "3br" | "4br+" | "office"
  addOns        Json     // { packing: boolean, storage: boolean, piano: boolean, ... }

  // Output
  estimateLow    Int  // in USD cents
  estimateHigh   Int  // in USD cents
  distanceMiles  Int?

  @@index([sessionId])
  @@index([leadId])
}

// ─────────────────────────────────────────────
// TRACKING EVENTS
// First-party behavioral analytics.
// IP is hashed (SHA-256) — never stored raw.
// ─────────────────────────────────────────────

model TrackingEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  sessionId String
  leadId    String?
  lead      Lead?   @relation(fields: [leadId], references: [id])

  event     TrackingEventType
  path      String?
  referrer  String?
  data      Json?    // event-specific payload

  // Enrichment (server-side)
  ipHash    String?  // SHA-256 of IP — privacy compliant
  device    DeviceType?
  geoCity   String?
  geoState  String?

  @@index([sessionId])
  @@index([leadId])
  @@index([event])
  @@index([createdAt])
}

enum TrackingEventType {
  PAGE_VIEW
  CTA_CLICK
  FORM_START
  FORM_ABANDON
  FORM_SUBMIT
  ESTIMATE_COMPLETE
  LOCATION_VIEWED
  PHONE_CLICK
  CHAT_OPEN
  CHAT_LEAD_CAPTURED
  CONSENT_ACCEPTED
  CONSENT_REJECTED
}

// ─────────────────────────────────────────────
// ADMIN USERS
// Sales team dashboard access via NextAuth.
// ─────────────────────────────────────────────

model AdminUser {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  email         String    @unique
  name          String?
  role          AdminRole @default(SALES_REP)
  lastLoginAt   DateTime?

  // NextAuth fields
  emailVerified DateTime?
  image         String?

  // NextAuth adapter relations
  accounts      Account[]
  sessions      Session[]

  @@index([email])
}

enum AdminRole {
  ADMIN
  SALES_MANAGER
  SALES_REP
}

// ─────────────────────────────────────────────
// NEXTAUTH v5 ADAPTER MODELS
// Required by @auth/prisma-adapter
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
