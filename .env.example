# ─────────────────────────────────────────────
# Armstrong Website — Environment Variables
# Copy to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/armstrong"

# ── NetSuite CRM ──────────────────────────────
# REST API with OAuth 1.0a
NETSUITE_ACCOUNT_ID=""
NETSUITE_CONSUMER_KEY=""
NETSUITE_CONSUMER_SECRET=""
NETSUITE_TOKEN_ID=""
NETSUITE_TOKEN_SECRET=""

# ── Email — Resend ────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_ADDRESS="no-reply@goarmstrong.com"
SALES_NOTIFICATION_EMAIL="sales@goarmstrong.com"

# ── CMS — Sanity ──────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
SANITY_API_TOKEN=""
SANITY_WEBHOOK_SECRET=""

# ── Auth — NextAuth.js v5 ────────────────────
AUTH_SECRET=""          # generate: openssl rand -base64 32
AUTH_TRUST_HOST=true    # required in production behind reverse proxy
NEXTAUTH_URL="http://localhost:3000"

# ── Sanity Studio Basic Auth (production) ────
STUDIO_BASIC_AUTH_USER=""
STUDIO_BASIC_AUTH_PASS=""

# ── Sanity Read Token (draft previews) ───────
SANITY_API_READ_TOKEN=""

# ── Bot Protection — Cloudflare Turnstile ─────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ── Rate Limiting — Upstash Redis ─────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Analytics — GA4 ──────────────────────────
# Keep existing property; new web stream
NEXT_PUBLIC_GA4_MEASUREMENT_ID="G-GZ7MVEHYW1"

# ── A/B Testing — GrowthBook ──────────────────
NEXT_PUBLIC_GROWTHBOOK_CLIENT_KEY=""

# ── Monitoring — Sentry ───────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ── GeoIP — MaxMind ───────────────────────────
# Download GeoLite2-City.mmdb to /data/GeoLite2-City.mmdb
MAXMIND_ACCOUNT_ID=""
MAXMIND_LICENSE_KEY=""
