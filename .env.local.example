# ============================================================
# Armstrong Website — .env.local.example
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.
# ============================================================

# ------------------------------------------------------------
# Analytics — Google Analytics 4
# ------------------------------------------------------------

# GA4 Measurement ID (format: G-XXXXXXXXXX)
# Google Analytics → Admin → Data Streams → your stream → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ------------------------------------------------------------
# Bot Protection — Cloudflare Turnstile
# ------------------------------------------------------------

# Public site key — safe to expose to the browser
# Cloudflare Dashboard → Turnstile → your widget → Site Key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Server-side verification secret — keep private
# Cloudflare Dashboard → Turnstile → your widget → Secret Key
TURNSTILE_SECRET_KEY=

# ------------------------------------------------------------
# CMS — Sanity v3
# ------------------------------------------------------------

# Sanity project ID — visible in the URL at sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Dataset name — usually "production"
NEXT_PUBLIC_SANITY_DATASET=production

# Read-only API token for server-side content fetches
# sanity.io/manage → API → Tokens → Add API token (Viewer role)
SANITY_API_READ_TOKEN=

# Write token used by the seed script (npm run seed:articles)
# sanity.io/manage → API → Tokens → Add API token (Editor role)
SANITY_API_WRITE_TOKEN=

# ------------------------------------------------------------
# Database — PostgreSQL (Prisma)
# ------------------------------------------------------------

# Full PostgreSQL connection string
# Example (local):    postgresql://postgres:password@localhost:5432/armstrong
# Example (Neon):     postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/armstrong?sslmode=require
# Example (Supabase): postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
DATABASE_URL=

# ------------------------------------------------------------
# Auth — NextAuth.js v5 (Google OAuth)
# ------------------------------------------------------------

# Random secret used to sign JWTs and cookies
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth client ID
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
AUTH_GOOGLE_ID=

# Google OAuth client secret
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
AUTH_GOOGLE_SECRET=

# ------------------------------------------------------------
# Email — Resend
# ------------------------------------------------------------

# Resend API key for sending transactional email (lead notifications, confirmations)
# resend.com → API Keys → Create API Key
RESEND_API_KEY=

# ------------------------------------------------------------
# Rate Limiting — Upstash Redis
# ------------------------------------------------------------
# If unset, rate limiting degrades gracefully to allow-all.
# The app works fine without these during local development.

# Upstash Redis REST endpoint URL
# upstash.com → Redis → your database → REST API → UPSTASH_REDIS_REST_URL
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST auth token
# upstash.com → Redis → your database → REST API → UPSTASH_REDIS_REST_TOKEN
UPSTASH_REDIS_REST_TOKEN=

# ------------------------------------------------------------
# CRM — NetSuite REST API (OAuth 1.0a)
# ------------------------------------------------------------
# If unset, leads are saved to PostgreSQL and emailed via Resend.
# NetSuite sync silently no-ops during local development.

# NetSuite account ID (e.g. 1234567 or 1234567_SB1 for sandbox)
# NetSuite → Setup → Company → Company Information → Account ID
NETSUITE_ACCOUNT_ID=

# OAuth 1.0a consumer key
# NetSuite → Setup → Integration → Manage Integrations → your integration
NETSUITE_CONSUMER_KEY=

# OAuth 1.0a consumer secret
NETSUITE_CONSUMER_SECRET=

# Access token ID
# NetSuite → Setup → Users/Roles → Access Tokens → New
NETSUITE_TOKEN_ID=

# Access token secret
NETSUITE_TOKEN_SECRET=

# ------------------------------------------------------------
# Cron Jobs
# ------------------------------------------------------------

# Shared secret sent in the Authorization header by cron callers
# to authenticate scheduled API route endpoints.
# Generate with: openssl rand -base64 32
CRON_SECRET=
